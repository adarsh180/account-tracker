generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String   @default("Admin")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Party {
  id           String     @id @default(cuid())
  name         String
  type         String     // BUYER or SELLER
  phone        String?
  address      String?    @db.Text
  gstNumber    String?
  paymentTerms Int        @default(0) // days
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  purchases    Purchase[]
  sales        Sale[]
  payments     Payment[]
}

model Purchase {
  id              String   @id @default(cuid())
  commodity       String   // Copper, MS_Scrap, Battery, etc.
  unit            String   // KG, MT, PCS
  quantity        Decimal  @db.Decimal(12, 3)
  rate            Decimal  @db.Decimal(12, 2)
  purchasePrice   Decimal  @db.Decimal(14, 2)
  laborCost       Decimal  @default(0) @db.Decimal(12, 2)
  transportCost   Decimal  @default(0) @db.Decimal(12, 2)
  loadingCost     Decimal  @default(0) @db.Decimal(12, 2)
  miscOverhead    Decimal  @default(0) @db.Decimal(12, 2)
  gstPercent      Decimal  @default(0) @db.Decimal(5, 2)
  gstAmount       Decimal  @default(0) @db.Decimal(12, 2)
  tcsPercent      Decimal  @default(0) @db.Decimal(5, 2)
  tcsAmount       Decimal  @default(0) @db.Decimal(12, 2)
  totalCost       Decimal  @db.Decimal(14, 2)
  partyId         String
  party           Party    @relation(fields: [partyId], references: [id])
  date            DateTime @default(now())
  notes           String?  @db.Text
  batchId         String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sales           Sale[]

  @@index([commodity])
  @@index([partyId])
  @@index([date])
}

model Sale {
  id            String    @id @default(cuid())
  commodity     String
  unit          String
  quantity      Decimal   @db.Decimal(12, 3)
  rate          Decimal   @db.Decimal(12, 2)
  gstPercent    Decimal   @default(0) @db.Decimal(5, 2)
  gstAmount     Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @db.Decimal(14, 2)
  bankAmount    Decimal   @db.Decimal(14, 2)
  cashAmount    Decimal   @db.Decimal(14, 2)
  sourceCommodity String? // Bulk item (e.g., MS Scrap) from which this was extracted
  batchId       String? // Link to a specific purchase lot
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id])
  partyId       String
  party         Party     @relation(fields: [partyId], references: [id])
  date          DateTime  @default(now())
  notes         String?   @db.Text
  isPaid        Boolean   @default(false)
  paidDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@index([commodity])
  @@index([partyId])
  @@index([date])
}

model Payment {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id])
  amount    Decimal  @db.Decimal(14, 2)
  mode      String   // BANK or CASH
  reference String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([partyId])
}

model Inventory {
  id           String   @id @default(cuid())
  commodity    String   @unique
  unit         String
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  avgCost      Decimal  @default(0) @db.Decimal(12, 2)
  lastUpdated  DateTime @default(now())
}

model ODAccount {
  id              String          @id @default(cuid())
  bankName        String
  odLimit         Decimal         @db.Decimal(14, 2)
  currentUtilized Decimal         @default(0) @db.Decimal(14, 2)
  interestRate    Decimal         @db.Decimal(5, 2) // annual %
  lastAccrualDate DateTime        @default(now())
  accruedInterest Decimal         @default(0) @db.Decimal(14, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  transactions    ODTransaction[]
}

model ODTransaction {
  id          String    @id @default(cuid())
  accountId   String
  account     ODAccount @relation(fields: [accountId], references: [id])
  amount      Decimal   @db.Decimal(14, 2)
  type        String    // DRAW or REPAY
  description String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([accountId])
  @@index([date])
}

model AnalysisSnapshot {
  id        String   @id @default(cuid())
  data      String   @db.LongText
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MonthlyExpense {
  id          String   @id @default(cuid())
  month       Int
  year        Int
  category    String   // RENT, OD_INTEREST, ELECTRICITY, SALARY, MISC
  amount      Decimal  @db.Decimal(14, 2)
  description String?  @db.Text
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([month, year, category])
  @@index([year])
  @@index([category])
}

model CommitteeInvestment {
  id              String   @id @default(cuid())
  committeeName   String   @default("Father's Committee")
  maturityAmount  Decimal  @db.Decimal(14, 2)
  startDate       DateTime
  maturityDate    DateTime
  totalMonths     Int      @default(13)
  isActive        Boolean  @default(true)
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  payments        CommitteePayment[]
}

model CommitteePayment {
  id              String              @id @default(cuid())
  committeeId     String
  committee       CommitteeInvestment @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  month           Int
  year            Int
  amount          Decimal             @db.Decimal(14, 2)
  isPaid          Boolean             @default(true)
  date            DateTime            @default(now())
  createdAt       DateTime            @default(now())

  @@unique([committeeId, month, year])
  @@index([committeeId])
}

model HomeDistribution {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(14, 2)
  recipient   String   // WIFE, SON, OTHER
  description String?  @db.Text
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([date])
}

model VisionMilestone {
  id                String   @id @default(cuid())
  fyYear            Int      @unique // e.g. 2026 = FY 2026-2027 start year
  turnoverTarget    Decimal  @db.Decimal(16, 2) // Revenue target for this FY
  profitTarget      Decimal  @db.Decimal(16, 2) // Net profit target
  valuationTarget   Decimal  @db.Decimal(16, 2) // Company valuation target
  actualTurnover    Decimal? @db.Decimal(16, 2) // Filled in from real data
  actualProfit      Decimal? @db.Decimal(16, 2)
  keyGoals          String?  @db.Text           // JSON array of goal strings
  achievements      String?  @db.Text           // JSON array of achieved items
  notes             String?  @db.Text
  isCompleted       Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([fyYear])
}
