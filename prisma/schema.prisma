generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String   @default("Admin")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AppConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model Party {
  id           String     @id @default(cuid())
  name         String
  type         String     // BUYER or SELLER
  phone        String?
  address      String?    @db.Text
  gstNumber    String?
  paymentTerms Int        @default(0) // days
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  purchases    Purchase[]
  sales        Sale[]
  payments     Payment[]
}

model Purchase {
  id              String   @id @default(cuid())
  commodity       String   // Copper, MS_Scrap, Battery, etc.
  unit            String   // KG, MT, PCS
  quantity        Decimal  @db.Decimal(12, 3)
  rate            Decimal  @db.Decimal(12, 2)
  purchasePrice   Decimal  @db.Decimal(14, 2)
  laborCost       Decimal  @default(0) @db.Decimal(12, 2)
  transportCost   Decimal  @default(0) @db.Decimal(12, 2)
  loadingCost     Decimal  @default(0) @db.Decimal(12, 2)
  miscOverhead    Decimal  @default(0) @db.Decimal(12, 2)
  gstPercent      Decimal  @default(0) @db.Decimal(5, 2)
  gstAmount       Decimal  @default(0) @db.Decimal(12, 2)
  tcsPercent      Decimal  @default(0) @db.Decimal(5, 2)
  tcsAmount       Decimal  @default(0) @db.Decimal(12, 2)
  totalCost       Decimal  @db.Decimal(14, 2)
  partyId         String
  party           Party    @relation(fields: [partyId], references: [id])
  date            DateTime @default(now())
  notes           String?  @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  sales           Sale[]

  @@index([commodity])
  @@index([partyId])
  @@index([date])
}

model Sale {
  id            String    @id @default(cuid())
  commodity     String
  unit          String
  quantity      Decimal   @db.Decimal(12, 3)
  rate          Decimal   @db.Decimal(12, 2)
  gstPercent    Decimal   @default(0) @db.Decimal(5, 2)
  gstAmount     Decimal   @default(0) @db.Decimal(14, 2)
  totalAmount   Decimal   @db.Decimal(14, 2)
  bankAmount    Decimal   @db.Decimal(14, 2)
  cashAmount    Decimal   @db.Decimal(14, 2)
  sourceCommodity String? // Bulk item (e.g., MS Scrap) from which this was extracted
  purchaseId    String?
  purchase      Purchase? @relation(fields: [purchaseId], references: [id])
  partyId       String
  party         Party     @relation(fields: [partyId], references: [id])
  date          DateTime  @default(now())
  notes         String?   @db.Text
  isPaid        Boolean   @default(false)
  paidDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@index([commodity])
  @@index([partyId])
  @@index([date])
}

model Payment {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id])
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id])
  amount    Decimal  @db.Decimal(14, 2)
  mode      String   // BANK or CASH
  reference String?
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([saleId])
  @@index([partyId])
}

model Inventory {
  id           String   @id @default(cuid())
  commodity    String   @unique
  unit         String
  quantity     Decimal  @default(0) @db.Decimal(12, 3)
  avgCost      Decimal  @default(0) @db.Decimal(12, 2)
  lastUpdated  DateTime @default(now())
}

model ODAccount {
  id              String          @id @default(cuid())
  bankName        String
  odLimit         Decimal         @db.Decimal(14, 2)
  currentUtilized Decimal         @default(0) @db.Decimal(14, 2)
  interestRate    Decimal         @db.Decimal(5, 2) // annual %
  lastAccrualDate DateTime        @default(now())
  accruedInterest Decimal         @default(0) @db.Decimal(14, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  transactions    ODTransaction[]
}

model ODTransaction {
  id          String    @id @default(cuid())
  accountId   String
  account     ODAccount @relation(fields: [accountId], references: [id])
  amount      Decimal   @db.Decimal(14, 2)
  type        String    // DRAW or REPAY
  description String?
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([accountId])
  @@index([date])
}

model AnalysisSnapshot {
  id        String   @id @default(cuid())
  data      String   @db.LongText
  createdAt DateTime @default(now())

  @@index([createdAt])
}
